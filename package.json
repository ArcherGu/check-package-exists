{
  "name": "check-package-exists",
  "version": "0.0.0-development",
  "packageManager": "pnpm@10.33.0",
  "description": "Check if the npm package exists",
  "author": "ArcherGu",
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/ArcherGu/check-package-exists.git"
  },
  "keywords": [
    "npm",
    "package",
    "exists"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=14"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm build && vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@esm2cjs/execa": "6.1.1-cjs.1",
    "global-dirs": "^4.0.0",
    "resolve": "^1.22.11"
  },
  "devDependencies": {
    "@lightwing/eslint-config": "1.0.152",
    "@types/node": "25.5.2",
    "@types/resolve": "1.20.6",
    "eslint": "10.1.0",
    "lint-staged": "16.4.0",
    "simple-git-hooks": "2.13.1",
    "tsdown": "^0.21.4",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json,yml}": [
      "eslint --fix"
    ]
  }
}
